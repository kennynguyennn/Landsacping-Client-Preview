<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Outsider Landscapes — Brisbane Landscape Design</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400&display=swap" rel="stylesheet" />
<style>

/* ─────────────────────────────────────────
   CONFIG & TOKENS
───────────────────────────────────────── */
:root {
  --c-bg:        #0e0f0b;
  --c-surface:   #161810;
  --c-card:      #1c1f15;
  --c-border:    rgba(180,170,130,0.12);
  --c-accent:    #b8a96a;
  --c-accent2:   #7a9e6e;
  --c-text:      #e8e2d0;
  --c-muted:     #7a7660;
  --c-star:      #d4a843;

  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body:    'Montserrat', sans-serif;
  --font-mono:    'JetBrains Mono', monospace;

  --radius-card:  24px;
  --radius-pill:  100px;

  --shadow-card:  0 4px 40px rgba(0,0,0,0.45);
  --shadow-glow:  0 0 40px rgba(184,169,106,0.12);

  --nav-h: 72px;
  --transition: 0.35s cubic-bezier(0.4,0,0.2,1);
}

[data-theme="light"] {
  --c-bg:       #f4f1e8;
  --c-surface:  #ede9da;
  --c-card:     #e8e4d5;
  --c-border:   rgba(100,90,60,0.15);
  --c-text:     #1c1a14;
  --c-muted:    #7a6e50;
  --shadow-card: 0 4px 40px rgba(0,0,0,0.10);
  --shadow-glow: 0 0 40px rgba(122,158,110,0.18);
}

/* ─────────────────────────────────────────
   RESET
───────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--c-bg);
  color: var(--c-text);
  font-family: var(--font-body);
  font-size: 15px;
  line-height: 1.6;
  overflow-x: hidden;
  transition: background var(--transition), color var(--transition);
}
img { display: block; width: 100%; object-fit: cover; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; border: none; background: none; font: inherit; color: inherit; }

/* ─────────────────────────────────────────
   NOISE TEXTURE OVERLAY
───────────────────────────────────────── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  background-size: 200px 200px;
}

/* ─────────────────────────────────────────
   GRADIENT MESH BACKGROUND
───────────────────────────────────────── */
.mesh-bg {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}
.mesh-bg span {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
  opacity: 0.18;
  animation: drift 18s ease-in-out infinite alternate;
}
.mesh-bg span:nth-child(1) {
  width: 700px; height: 700px;
  background: radial-gradient(circle, #7a9e6e 0%, transparent 70%);
  top: -200px; left: -200px;
  animation-delay: 0s;
}
.mesh-bg span:nth-child(2) {
  width: 600px; height: 600px;
  background: radial-gradient(circle, #b8a96a 0%, transparent 70%);
  bottom: -150px; right: -150px;
  animation-delay: -6s;
}
.mesh-bg span:nth-child(3) {
  width: 400px; height: 400px;
  background: radial-gradient(circle, #4a6e3a 0%, transparent 70%);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  animation-delay: -12s;
}
@keyframes drift {
  0%   { transform: translate(0,0) scale(1); }
  100% { transform: translate(60px, 40px) scale(1.1); }
}

/* ─────────────────────────────────────────
   NAV
───────────────────────────────────────── */
nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 clamp(1.5rem, 5vw, 4rem);
  background: rgba(14,15,11,0.7);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--c-border);
  transition: background var(--transition);
}
[data-theme="light"] nav { background: rgba(244,241,232,0.75); }

.nav-logo {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 300;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.nav-logo span { color: var(--c-accent2); font-style: italic; }

.nav-links {
  display: flex;
  gap: 2.5rem;
  align-items: center;
  list-style: none;
}
.nav-links a {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-muted);
  transition: color var(--transition);
}
.nav-links a:hover { color: var(--c-text); }

.nav-actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.theme-btn {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: var(--c-card);
  border: 1px solid var(--c-border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  transition: background var(--transition), transform 0.2s;
}
.theme-btn:hover { background: var(--c-surface); transform: rotate(20deg); }

.nav-cta {
  padding: 0.5rem 1.4rem;
  background: var(--c-accent);
  color: #0e0f0b;
  border-radius: var(--radius-pill);
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  display: inline-block;
}
.nav-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(184,169,106,0.35);
  background: #cfc07e;
}

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 6px;
}
.hamburger span {
  display: block;
  width: 22px; height: 2px;
  background: var(--c-text);
  border-radius: 2px;
  transition: var(--transition);
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile Nav Overlay */
.mobile-nav {
  position: fixed;
  inset: 0;
  z-index: 99;
  background: var(--c-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition);
}
.mobile-nav.open { opacity: 1; pointer-events: all; }
.mobile-nav a {
  font-family: var(--font-display);
  font-size: clamp(2rem, 8vw, 3.5rem);
  font-weight: 300;
  color: var(--c-text);
  transition: color var(--transition);
}
.mobile-nav a:hover { color: var(--c-accent); }

/* ─────────────────────────────────────────
   MARQUEE
───────────────────────────────────────── */
.marquee-wrap {
  overflow: hidden;
  border-top: 1px solid var(--c-border);
  border-bottom: 1px solid var(--c-border);
  background: var(--c-surface);
  padding: 0.7rem 0;
  position: relative;
  z-index: 1;
}
.marquee-track {
  display: flex;
  gap: 0;
  width: max-content;
  animation: marquee 28s linear infinite;
}
.marquee-item {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 0 2.5rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--c-muted);
  white-space: nowrap;
}
.marquee-item .dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--c-accent);
  flex-shrink: 0;
}
@keyframes marquee {
  0%   { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ─────────────────────────────────────────
   HERO
───────────────────────────────────────── */
.hero {
  min-height: 100svh;
  padding-top: var(--nav-h);
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  gap: 4rem;
  padding-left: clamp(1.5rem, 6vw, 6rem);
  padding-right: clamp(1.5rem, 4vw, 4rem);
  padding-bottom: 4rem;
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  right: 0; top: 0; bottom: 0;
  width: 52%;
  background: var(--c-card);
  z-index: -1;
  clip-path: polygon(8% 0%, 100% 0%, 100% 100%, 0% 100%);
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--c-accent2);
  margin-bottom: 1.5rem;
}
.hero-eyebrow::before {
  content: '';
  display: block;
  width: 32px; height: 1px;
  background: var(--c-accent2);
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(3.2rem, 7vw, 6.5rem);
  font-weight: 300;
  line-height: 1.0;
  letter-spacing: -0.01em;
  margin-bottom: 1.8rem;
}
.hero-title em {
  font-style: italic;
  color: var(--c-accent);
}

.hero-sub {
  font-size: 0.9rem;
  color: var(--c-muted);
  max-width: 420px;
  line-height: 1.8;
  margin-bottom: 2.5rem;
}

.hero-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  align-items: center;
}
.btn-primary {
  padding: 0.85rem 2.2rem;
  background: var(--c-accent);
  color: #0e0f0b;
  border-radius: var(--radius-pill);
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: transform 0.2s, box-shadow 0.2s;
  display: inline-block;
}
.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(184,169,106,0.35);
}
.btn-ghost {
  padding: 0.85rem 2.2rem;
  border: 1px solid var(--c-border);
  border-radius: var(--radius-pill);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-muted);
  transition: border-color var(--transition), color var(--transition), transform 0.2s;
  display: inline-block;
}
.btn-ghost:hover {
  border-color: var(--c-accent);
  color: var(--c-text);
  transform: translateY(-3px);
}

.hero-rating-pill {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-top: 2rem;
  padding: 0.5rem 1rem;
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-pill);
  width: fit-content;
  font-size: 0.75rem;
}
.stars { color: var(--c-star); letter-spacing: 2px; font-size: 0.85rem; }

.hero-visual {
  position: relative;
  height: clamp(380px, 60vh, 600px);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.hero-visual-img {
  width: 100%; height: 100%;
  background: linear-gradient(135deg, #2a3d22 0%, #1a2a18 40%, #3a4a2a 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.hero-visual-img::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 30% 40%, rgba(122,158,110,0.3) 0%, transparent 55%),
    radial-gradient(ellipse at 70% 70%, rgba(184,169,106,0.2) 0%, transparent 50%);
}
.hero-visual-label {
  position: absolute;
  bottom: 1.5rem;
  left: 1.5rem;
  background: rgba(14,15,11,0.75);
  backdrop-filter: blur(12px);
  border: 1px solid var(--c-border);
  border-radius: 14px;
  padding: 0.7rem 1rem;
  font-size: 0.7rem;
  font-family: var(--font-mono);
  letter-spacing: 0.08em;
  color: var(--c-muted);
}
.hero-visual-label strong { display: block; color: var(--c-text); font-size: 0.82rem; margin-bottom: 0.15rem; }

.hero-badge {
  position: absolute;
  top: 1.5rem; right: 1.5rem;
  background: var(--c-accent);
  color: #0e0f0b;
  border-radius: 14px;
  padding: 0.6rem 1rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}

/* ─────────────────────────────────────────
   SECTION SHARED
───────────────────────────────────────── */
section {
  position: relative;
  z-index: 1;
  padding: clamp(4rem, 8vw, 8rem) clamp(1.5rem, 6vw, 6rem);
}

.section-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--c-accent2);
  margin-bottom: 1rem;
}
.section-eyebrow::before {
  content: '';
  display: block;
  width: 24px; height: 1px;
  background: var(--c-accent2);
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 5vw, 4rem);
  font-weight: 300;
  line-height: 1.1;
  margin-bottom: 1rem;
}
.section-title em { font-style: italic; color: var(--c-accent); }

.section-sub {
  font-size: 0.88rem;
  color: var(--c-muted);
  max-width: 480px;
  line-height: 1.85;
  margin-bottom: 3.5rem;
}

/* ─────────────────────────────────────────
   SERVICES BENTO
───────────────────────────────────────── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.service-card {
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-card);
  padding: 2rem 1.8rem;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  position: relative;
  overflow: hidden;
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--c-accent2), var(--c-accent), transparent);
  opacity: 0;
  transition: opacity 0.3s;
}
.service-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-glow), var(--shadow-card);
  border-color: rgba(184,169,106,0.25);
}
.service-card:hover::before { opacity: 1; }

.service-card.featured {
  grid-column: span 2;
  background: linear-gradient(135deg, var(--c-card) 0%, rgba(122,158,110,0.08) 100%);
  padding: 2.5rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
}

.service-icon {
  width: 48px; height: 48px;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--c-accent2), var(--c-accent));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.4rem;
  margin-bottom: 1.3rem;
  flex-shrink: 0;
}

.service-name {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 400;
  margin-bottom: 0.6rem;
}

.service-desc {
  font-size: 0.82rem;
  color: var(--c-muted);
  line-height: 1.75;
}

.service-tag {
  display: inline-block;
  margin-top: 1rem;
  padding: 0.3rem 0.9rem;
  background: rgba(122,158,110,0.12);
  border: 1px solid rgba(122,158,110,0.2);
  border-radius: var(--radius-pill);
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  color: var(--c-accent2);
  text-transform: uppercase;
}

/* ─────────────────────────────────────────
   PROCESS
───────────────────────────────────────── */
.process-section { background: var(--c-surface); }

.process-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  position: relative;
  margin-top: 1rem;
}
.process-steps::before {
  content: '';
  position: absolute;
  top: 28px; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--c-accent), var(--c-accent2), transparent);
}

.process-step {
  padding: 2rem 1.5rem 1.5rem;
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-card);
  position: relative;
  transition: transform 0.3s, box-shadow 0.3s;
}
.process-step:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-glow);
}

.step-num {
  width: 56px; height: 56px;
  border-radius: 50%;
  background: var(--c-bg);
  border: 2px solid var(--c-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--c-accent);
  margin-bottom: 1.5rem;
  position: relative;
  z-index: 1;
}

.step-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 400;
  margin-bottom: 0.5rem;
}

.step-desc {
  font-size: 0.8rem;
  color: var(--c-muted);
  line-height: 1.7;
}

/* ─────────────────────────────────────────
   TESTIMONIALS
───────────────────────────────────────── */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.testimonial-card {
  background: var(--c-card);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-card);
  padding: 2rem;
  transition: transform 0.3s, box-shadow 0.3s, border-color 0.3s;
  position: relative;
  overflow: hidden;
}
.testimonial-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-glow), var(--shadow-card);
  border-color: rgba(184,169,106,0.25);
}
.testimonial-card::after {
  content: '"';
  position: absolute;
  bottom: -1rem;
  right: 1.5rem;
  font-family: var(--font-display);
  font-size: 8rem;
  color: var(--c-accent);
  opacity: 0.07;
  line-height: 1;
  pointer-events: none;
}

.testimonial-stars {
  color: var(--c-star);
  font-size: 0.85rem;
  letter-spacing: 3px;
  margin-bottom: 1rem;
}

.testimonial-text {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 300;
  line-height: 1.75;
  color: var(--c-text);
  margin-bottom: 1.5rem;
  font-style: italic;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
.author-avatar {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--c-accent2), var(--c-accent));
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 0.8rem;
  color: #0e0f0b;
  flex-shrink: 0;
}
.author-name { font-size: 0.82rem; font-weight: 600; }
.author-meta {
  font-size: 0.72rem;
  color: var(--c-muted);
  font-family: var(--font-mono);
  letter-spacing: 0.04em;
}

/* ─────────────────────────────────────────
   ABOUT
───────────────────────────────────────── */
.about-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}

.about-visual { position: relative; }

.about-img {
  width: 100%;
  aspect-ratio: 4/5;
  border-radius: var(--radius-card);
  background: linear-gradient(135deg, #1e2e18 0%, #2d4025 50%, #1a2a15 100%);
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}
.about-img::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 40% 30%, rgba(122,158,110,0.25) 0%, transparent 60%),
    radial-gradient(ellipse at 70% 80%, rgba(184,169,106,0.15) 0%, transparent 50%);
}

.about-img-placeholder {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}
.about-img-placeholder .icon { font-size: 3rem; opacity: 0.3; }
.about-img-placeholder .label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.15em;
  color: var(--c-muted);
  text-transform: uppercase;
  text-align: center;
  padding: 0 2rem;
}

.about-float-card {
  position: absolute;
  bottom: 1.5rem;
  right: -2rem;
  background: var(--c-card);
